# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Virtual environments
.venv/
venv/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
coverage/
htmlcov/

# Linting
.ruff_cache/

# Environment variables — plaintext ignored, encrypted (.enc) committed
**/*.env
**/*.env.prod
!**/*.env.enc
!**/*.env.prod.enc
.envrc
.image-tag

# Logs
*.log

# IDE
.vscode/
.idea/
*.swp
*~

# macOS
.DS_Store

# Node (frontend)
node_modules/
dist/

# Claude
.claude/*
!.claude/commands/
!.claude/commands/COMMANDS.md
# Benchmark results (generated, not versioned)
backend/benchmarks/eval/results/
!backend/benchmarks/eval/results/.gitkeep
backend/benchmarks/load/results/

# UI/UX ideas - screenshots, mockups, etc.
ui/
