# Coupette — Environment Configuration
# Copy to .env:  cp .env.example .env
#
# Single source of truth — used by all services (backend, scraper, bot)
# and Docker Compose. No per-service .env files needed.
#
# Usage:
#   Bare metal:  make dev-backend / make dev-scrape  (reads this .env via pydantic-settings)
#   Docker:      make up                 (compose reads this .env for interpolation)
#   Production:  set DB_HOST to external postgres IP

# ============================================================================
# Database (required — pydantic-settings fails fast if missing)
# ============================================================================
DB_USER=saq_sommelier
DB_PASSWORD=saq_sommelier
DB_NAME=saq_sommelier

DB_HOST=localhost
DB_PORT=5432

REDIS_URL=redis://localhost:6379/0

# Connection pool (defaults are fine for most setups)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=5


# ============================================================================
# Application
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false
DATABASE_ECHO=false
#! JWT signing key — generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=


# ============================================================================
# Scraper
# ============================================================================
SCRAPE_LIMIT=500 #! 0 = all products (production)


# ============================================================================
# Telegram Bot
# ============================================================================
#! Required for bot to function and for OAuth with Telegram
TELEGRAM_BOT_TOKEN=
#! Shared secret for bot→backend auth
BOT_SECRET=
BACKEND_URL=http://localhost:8001
#! seconds (60 for dev, 21600 for prod = 6h)
NOTIFICATION_POLL_INTERVAL=60


# ============================================================================
# AI / Embeddings
# ============================================================================
#! Required for --embed-sync (scraper)
OPENAI_API_KEY=
#! Required for /recommend (backend)
ANTHROPIC_API_KEY=


# ============================================================================
# Deploy tools
# ============================================================================
#! Telegram ID of the admin user — used by: make create-admin
ADMIN_TELEGRAM_ID=
#! Admin email — must match the OAuth provider email for auto-merge on first login
ADMIN_EMAIL=


# ============================================================================
# Frontend (dev only — prod VITE_* vars are set in deploy/deploy_frontend.sh)
# ============================================================================
VITE_TELEGRAM_BOT_USERNAME=


# ============================================================================
# Load testing (dev only — used by k6 runner scripts)
# ============================================================================
#! Grab from DevTools → Application → Local Storage → access_token (expires every 7 days)
K6_JWT=
K6_BASE_URL=


# ============================================================================
# Email (Resend)
# ============================================================================
#! Required in production — get from resend.com/api-keys
RESEND_API_KEY=


# ============================================================================
# OAuth
# ============================================================================
#! Create at https://github.com/settings/developers — separate apps for dev and prod
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

#! Create at https://console.cloud.google.com/apis/credentials — separate clients for dev and prod
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

#! Override to ngrok URL in local dev
FRONTEND_URL=https://coupette.club
#! Backend URL — used for Google OAuth redirect_uri (must match GCP authorized redirect URIs)
BACKEND_URL=https://coupette.club
