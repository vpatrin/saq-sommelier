[Unit]
Description=SAQ Sommelier scraper
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
WorkingDirectory=/opt/saq-sommelier
ExecStart=/usr/bin/docker compose run --rm scraper python -m scraper scrape
ExecStart=/usr/bin/docker compose run --rm scraper python -m scraper enrich
ExecStart=/usr/bin/docker compose run --rm scraper python -m scraper embed
